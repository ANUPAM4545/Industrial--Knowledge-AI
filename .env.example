# ═══════════════════════════════════════════════════════════════
#   ForgeMind AI — Environment Variables
#   Copy this file to .env and fill in your values.
# ═══════════════════════════════════════════════════════════════

# ─── Application ────────────────────────────────────────────────
APP_NAME="ForgeMind AI"
APP_ENV=development
APP_DEBUG=true
APP_VERSION=1.0.0

# ─── Backend API ─────────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
APP_SECRET_KEY=change-me-to-a-random-64-char-secret
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── JWT Authentication ──────────────────────────────────────────
JWT_SECRET_KEY=change-me-to-a-random-jwt-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── PostgreSQL Database ─────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=forgemind_db
POSTGRES_USER=forgemind
POSTGRES_PASSWORD=forgemind_secure_password
DATABASE_URL=postgresql+asyncpg://forgemind:forgemind_secure_password@postgres:5432/forgemind_db

# ─── Qdrant Vector Database ──────────────────────────────────────
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=forgemind_knowledge
QDRANT_VECTOR_SIZE=1024

# ─── Redis ──────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redis_secure_password
REDIS_URL=redis://:redis_secure_password@redis:6379/0

# ─── AI / LLM Configuration ─────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_API_BASE=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=2048

# ─── Embedding Model ────────────────────────────────────────────
EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
EMBEDDING_DIMENSION=1024
EMBEDDING_BATCH_SIZE=32

# ─── AI Service ─────────────────────────────────────────────────
AI_SERVICE_HOST=0.0.0.0
AI_SERVICE_PORT=8001
AI_SERVICE_URL=http://ai-service:8001

# ─── RAG Configuration ──────────────────────────────────────────
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=64
RAG_TOP_K=5
RAG_SCORE_THRESHOLD=0.7

# ─── File Upload ────────────────────────────────────────────────
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE_MB=50
ALLOWED_EXTENSIONS=pdf,docx,txt,png,jpg,jpeg,tiff

# ─── OCR ────────────────────────────────────────────────────────
OCR_ENABLED=true
TESSERACT_CMD=/usr/bin/tesseract
OCR_LANGUAGE=eng

# ─── Frontend (Vite) ────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000
VITE_AI_SERVICE_URL=http://localhost:8001
VITE_APP_NAME="ForgeMind AI"
VITE_APP_VERSION=1.0.0

# ─── pgAdmin (Development) ──────────────────────────────────────
PGADMIN_DEFAULT_EMAIL=admin@forgemind.ai
PGADMIN_DEFAULT_PASSWORD=pgadmin_password

# ─── Celery / Worker ────────────────────────────────────────────
CELERY_BROKER_URL=redis://:redis_secure_password@redis:6379/1
CELERY_RESULT_BACKEND=redis://:redis_secure_password@redis:6379/2
CELERY_WORKER_CONCURRENCY=4

# ─── Logging ────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json
