# ═══════════════════════════════════════════════════════════════
#   NEXO — Environment Variables
#   Copy this file to .env and fill in your values.
# ═══════════════════════════════════════════════════════════════

# ─── Application ────────────────────────────────────────────────
APP_NAME="NEXO"
APP_ENV=development
APP_DEBUG=true

# ─── Backend API ─────────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
APP_SECRET_KEY=change-me-to-a-random-64-char-secret
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── Authentication ──────────────────────────────────────────────
VITE_CLERK_PUBLISHABLE_KEY=pk_test_placeholder_key
CLERK_SECRET_KEY=sk_test_placeholder_key

# ─── PostgreSQL Database ─────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=nexo_db
POSTGRES_USER=nexo
POSTGRES_PASSWORD=nexo_secure_password
DATABASE_URL=postgresql+asyncpg://nexo:nexo_secure_password@postgres:5432/nexo_db

# ─── Qdrant Vector Database ──────────────────────────────────────
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=nexo_knowledge
QDRANT_VECTOR_SIZE=1024

# ─── Redis ──────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redis_secure_password
REDIS_URL=redis://:redis_secure_password@redis:6379/0

# ─── AI / LLM Configuration ─────────────────────────────────────
LLM_PROVIDER=gemini

GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

ANTHROPIC_API_KEY=
OLLAMA_HOST=http://localhost:11434

# ─── Embedding Model ────────────────────────────────────────────
EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
EMBEDDING_DIMENSION=1024

# ─── AI Microservice & RAG ──────────────────────────────────────
AI_SERVICE_URL=http://ai-service:8001
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=64
RAG_TOP_K=5

# ─── File Processing & OCR ──────────────────────────────────────
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE_MB=50
OCR_ENABLED=true
TESSERACT_CMD=/usr/bin/tesseract

# ─── Frontend (Vite) ────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000
VITE_APP_NAME="NEXO"
VITE_CONTACT_EMAIL=support@example.com

# ─── Celery Worker ──────────────────────────────────────────────
CELERY_BROKER_URL=redis://:redis_secure_password@redis:6379/1
CELERY_RESULT_BACKEND=redis://:redis_secure_password@redis:6379/2

# ─── Logging ────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json
