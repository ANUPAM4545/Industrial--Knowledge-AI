# ─────────────────────────────────────────────────
# NEXO — .gitignore
# ─────────────────────────────────────────────────

# ─── Environment Variables ───────────────────────
.env
.env.local
.env.production
.env.staging
*.env

# ─── Node / Frontend ─────────────────────────────
node_modules/
frontend/node_modules/
frontend/dist/
frontend/build/
frontend/.vite/
frontend/coverage/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/

# ─── Python / Backend ────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
.venv/
env/
ENV/
*.egg-info/
dist/
build/
.eggs/
*.egg
.mypy_cache/
.ruff_cache/
.pytest_cache/
htmlcov/
.coverage
coverage.xml
*.cover
.hypothesis/

# ─── Docker ──────────────────────────────────────
.docker/

# ─── IDE / Editors ───────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ─── Uploads / Data ──────────────────────────────
uploads/
backend/uploads/
ai-service/uploads/
*.pdf
*.docx
!docs/**/*.pdf

# ─── Logs ────────────────────────────────────────
logs/
*.log
log/

# ─── Database ────────────────────────────────────
*.db
*.sqlite
*.sqlite3
postgres-data/
pgdata/

# ─── Qdrant ──────────────────────────────────────
qdrant_storage/

# ─── Redis ───────────────────────────────────────
dump.rdb

# ─── Certificates ────────────────────────────────
*.pem
*.key
*.crt
*.csr
ssl/

# ─── Secrets ─────────────────────────────────────
secrets/
*.secret

# ─── Testing ─────────────────────────────────────
.pytest_cache/
test-results/
playwright-report/

# ─── Misc ────────────────────────────────────────
.gemini/
*.tmp
*.bak
.cache/
